# =============================================
# MUNIM — Environment Variables Reference
# Copy this file to .env and fill in values.
# NEVER commit .env to git.
# =============================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/munim?sslmode=require

# --- AI / LLM (Google Gemini 2.0 Flash — Free tier) ---
GOOGLE_API_KEY=AIza...

# --- Celery + Redis (Upstash — Free tier) ---
CELERY_BROKER_URL=rediss://:password@xxx.upstash.io:6380/0
CELERY_RESULT_BACKEND=rediss://:password@xxx.upstash.io:6380/0

# --- File Storage (Cloudflare R2 — Free tier) ---
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=munim-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# --- WhatsApp Business API (Meta Cloud API) ---
WHATSAPP_PHONE_NUMBER_ID=xxx
WHATSAPP_ACCESS_TOKEN=EAAx...
WHATSAPP_VERIFY_TOKEN=your_chosen_verify_string

# --- Google OAuth (NextAuth.js) ---
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# --- Razorpay (Payments) ---
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx

# --- Monitoring ---
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# --- Email (Resend — Free tier) ---
RESEND_API_KEY=re_xxx

# --- App Config ---
APP_ENV=development       # development | production
APP_SECRET_KEY=generate_with_openssl_rand_hex_32
CORS_ORIGINS=http://localhost:3000
FILE_DELETE_AFTER_DAYS=30
MAX_FILE_SIZE_MB=50
